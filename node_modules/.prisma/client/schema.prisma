generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id             String              @id @default(uuid()) @db.Char(36)
  email          String              @unique @db.VarChar(255)
  passwordHash   String              @map("password_hash") @db.VarChar(255)
  role           String              @default("user") @db.VarChar(20)
  createdAt      DateTime            @default(now()) @map("created_at")
  paymentDetails UserPaymentDetails?
  withdrawals    Withdrawal[]

  @@map("users")
}

model Song {
  id            String   @id @default(uuid()) @db.Char(36)
  title         String   @db.VarChar(200)
  artist        String   @db.VarChar(200)
  fileUrl       String   @map("file_url") @db.Text
  coverImageUrl String   @map("cover_image_url") @db.Text
  duration      Float
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([isActive])
  @@index([createdAt])
  @@map("songs")
}

model PlatformSetting {
  id           String   @id @db.VarChar(64)
  musicEnabled Boolean  @default(true) @map("music_enabled")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("platform_settings")
}

model WithdrawalSetting {
  id             String   @id @db.VarChar(64)
  paypalEnabled  Boolean  @default(true) @map("paypal_enabled")
  revolutEnabled Boolean  @default(true) @map("revolut_enabled")
  bankEnabled    Boolean  @default(true) @map("bank_enabled")
  cryptoEnabled  Boolean  @default(true) @map("crypto_enabled")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("withdrawal_settings")
}

model CryptoConfig {
  id        String          @id @default(uuid()) @db.Char(36)
  coin      String          @unique @db.VarChar(64)
  isEnabled Boolean         @default(true) @map("is_enabled")
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")
  networks  CryptoNetwork[]

  @@map("crypto_configs")
}

model CryptoNetwork {
  id             String       @id @default(uuid()) @db.Char(36)
  cryptoConfigId String       @map("crypto_config_id") @db.Char(36)
  name           String       @db.VarChar(64)
  isEnabled      Boolean      @default(true) @map("is_enabled")
  cryptoConfig   CryptoConfig @relation(fields: [cryptoConfigId], references: [id], onDelete: Cascade)

  @@unique([cryptoConfigId, name])
  @@index([cryptoConfigId])
  @@map("crypto_networks")
}

model UserPaymentDetails {
  id                String   @id @default(uuid()) @db.Char(36)
  userId            String   @unique @map("user_id") @db.Char(36)
  paypalEmail       String?  @map("paypal_email") @db.VarChar(255)
  paypalName        String?  @map("paypal_name") @db.VarChar(255)
  paypalPaypalId    String?  @map("paypal_paypal_id") @db.VarChar(255)
  revolutFullName   String?  @map("revolut_full_name") @db.VarChar(255)
  revolutIban       String?  @map("revolut_iban") @db.VarChar(255)
  revolutBic        String?  @map("revolut_bic") @db.VarChar(255)
  revolutTag        String?  @map("revolut_tag") @db.VarChar(255)
  bankAccountName   String?  @map("bank_account_name") @db.VarChar(255)
  bankSortCode      String?  @map("bank_sort_code") @db.VarChar(255)
  bankAccountNumber String?  @map("bank_account_number") @db.VarChar(255)
  bankBankName      String?  @map("bank_bank_name") @db.VarChar(255)
  bankIban          String?  @map("bank_iban") @db.VarChar(255)
  bankBicSwift      String?  @map("bank_bic_swift") @db.VarChar(255)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_payment_details")
}

model Withdrawal {
  id        String              @id @default(uuid()) @db.Char(36)
  userId    String              @map("user_id") @db.Char(36)
  method    String              @db.VarChar(20)
  status    String              @default("pending") @db.VarChar(20)
  createdAt DateTime            @default(now()) @map("created_at")
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  snapshot  WithdrawalSnapshot?

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@map("withdrawals")
}

model WithdrawalSnapshot {
  withdrawalId  String     @id @map("withdrawal_id") @db.Char(36)
  email         String?    @db.VarChar(255)
  name          String?    @db.VarChar(255)
  paypalId      String?    @map("paypal_id") @db.VarChar(255)
  fullName      String?    @map("full_name") @db.VarChar(255)
  iban          String?    @db.VarChar(255)
  bic           String?    @db.VarChar(255)
  tag           String?    @db.VarChar(255)
  accountName   String?    @map("account_name") @db.VarChar(255)
  sortCode      String?    @map("sort_code") @db.VarChar(255)
  accountNumber String?    @map("account_number") @db.VarChar(255)
  bankName      String?    @map("bank_name") @db.VarChar(255)
  bicSwift      String?    @map("bic_swift") @db.VarChar(255)
  coin          String?    @db.VarChar(64)
  network       String?    @db.VarChar(64)
  walletAddress String?    @map("wallet_address") @db.VarChar(255)
  withdrawal    Withdrawal @relation(fields: [withdrawalId], references: [id], onDelete: Cascade)

  @@map("withdrawal_snapshots")
}
